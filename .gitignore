# build outputs
target/
result

# render artifacts — never commit produced videos or generated narration.
# (Committed media ASSETS — test fixtures, music beds — are fine and go
# through git-lfs; see .gitattributes.)
build/
examples/*/audio/

# env / editor  (.envrc IS committed — it only says `use flake`)
.direnv/
.env
.DS_Store
*.log

# analyze output (extracted audio + transcripts of reference videos)
analysis/

# videoeditor preview output
template-previews/

# trunk build output (the committed copy lives in crates/videoeditor-record/ui)
crates/videoeditor-record-ui/dist/
# playwright artifacts
e2e/test-results/
e2e/playwright-report/
